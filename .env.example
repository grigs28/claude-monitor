# ============================================
# 智能确认器 配置文件
# ============================================

# ---------- AI 模型配置（--ai 模式生效）----------
# 建议使用本地模型：免费、快速、保护隐私

# Qwen 本地 API（推荐）
QWEN_API_URL=http://192.168.0.70:5564/v1/chat/completions   # API 地址
QWEN_MODEL=/opt/models/Qwen/Qwen3.5-27B-FP8                 # 模型路径
QWEN_TIMEOUT=10                                              # AI 请求超时（秒）
AI_CONTEXT_SIZE=1000                                         # 发送给 AI 的屏幕字符数

# ---------- 通用配置 ----------
RULE_CONTEXT_SIZE=1000   # 规则模式截取屏幕字符数
HEARTBEAT_INTERVAL=60    # 无事件时心跳输出间隔（秒）
COOLDOWN=5               # 确认后冷却秒数，防止重复触发

# ---------- Hook 模式配置（--hook 模式生效）----------
HOOK_ALLOW_PATTERNS=     # 额外允许的命令模式（逗号分隔正则）
HOOK_DENY_PATTERNS=      # 额外拒绝的命令模式（逗号分隔正则）
HOOK_LOG_FILE=           # 日志路径（默认同目录 hook.log）
