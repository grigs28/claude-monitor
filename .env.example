# AI Configuration
# AI 模型配置

# ⚠️ 重要：强烈建议使用本地 AI 模型！
# - 免费用
# - 响应快
# - 保护隐私
# - 无网络限制

# Qwen 本地 API 配置（推荐）
QWEN_API_URL=http://192.168.0.70:5564/v1/chat/completions
QWEN_MODEL=/opt/models/Qwen/Qwen3.5-27B-FP8
QWEN_TIMEOUT=60

# Moonshot AI (Kimi) API 配置（⚠️ 需付费，按使用量计费）
# 如果使用在线 API，会产生费用！
# MOONSHOT_API_KEY=your_api_key_here
# MOONSHOT_API_URL=https://api.moonshot.cn/v1
# MOONSHOT_MODEL=moonshot-v1-8k

# 通用配置
AI_MODE=rule  # rule 或 ai
CHECK_INTERVAL=2  # 检查间隔（秒）
CONFIRM_TIMEOUT=60  # AI 确认超时（秒）

# 💡 费用提醒
# - 本地模型: 免费
# - 在线 API: 按 token 计费
# - 建议: 优先使用本地模型，AI 模式仅在复杂场景使用
